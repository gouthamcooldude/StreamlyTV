<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:gravity="center_vertical"
            android:background="@color/bg_surface">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/text_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Settings"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingStart="8dp" />
        </LinearLayout>

        <!-- Section: Playback -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PLAYBACK"
            android:textColor="@color/accent_blue"
            android:textSize="12sp"
            android:padding="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:background="@color/bg_surface">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Hardware Decoder"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />
            <Switch
                android:id="@+id/switchHwDecoder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:background="@color/bg_surface"
            android:layout_marginTop="1dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Audio Passthrough (Dolby 5.1)"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sends AC3/EAC3 directly to soundbar"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>
            <Switch
                android:id="@+id/switchAudioPassthrough"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Buffer -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@color/bg_surface"
            android:layout_marginTop="1dp">
            <TextView
                android:id="@+id/labelBuffer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Buffer: 10s"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />
            <SeekBar
                android:id="@+id/seekBarBuffer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="30"
                android:progress="10"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Section: Language -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LANGUAGE FILTER"
            android:textColor="@color/accent_blue"
            android:textSize="12sp"
            android:padding="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:background="@color/bg_surface">
            <CheckBox
                android:id="@+id/checkEnglish"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="English"
                android:textColor="@color/text_primary" />
            <CheckBox
                android:id="@+id/checkTelugu"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Telugu"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <!-- Section: Background Scan -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BACKGROUND SCANNER"
            android:textColor="@color/accent_blue"
            android:textSize="12sp"
            android:padding="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@color/bg_surface">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Auto-scans newest content (last 30 days) for 4K and 5.1 audio when Fire TV is idle on WiFi."
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/scanStatusLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Scan status: checking..."
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnScanNow"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Scan Now"
                    android:backgroundTint="@color/accent_blue"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btnCancelScan"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Cancel Scan"
                    android:backgroundTint="@color/accent_red" />

            </LinearLayout>
        </LinearLayout>

        <!-- Section: EPG -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="EPG / TV GUIDE"
            android:textColor="@color/accent_blue"
            android:textSize="12sp"
            android:padding="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@color/bg_surface">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="XMLTV EPG URL"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
            <EditText
                android:id="@+id/inputEpgUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="http://provider.com/epg.xml"
                android:inputType="textUri"
                android:singleLine="true"
                android:layout_marginTop="4dp" />
            <Button
                android:id="@+id/btnSaveEpg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Save EPG"
                android:layout_marginTop="8dp"
                android:backgroundTint="@color/accent_blue" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
