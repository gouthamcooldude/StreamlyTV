<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/bg_surface"
    app:cardCornerRadius="8dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Poster Image -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="160dp">

            <ImageView
                android:id="@+id/vodPoster"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_movie_placeholder" />

            <!-- Watched dot (top left) -->
            <View
                android:id="@+id/watchedDot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_margin="6dp"
                android:background="@drawable/dot_watched"
                android:visibility="gone" />

            <!-- Resume bar (bottom of poster) -->
            <ProgressBar
                android:id="@+id/resumeBar"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_gravity="bottom"
                android:progressTint="@color/accent_blue"
                android:progressBackgroundTint="#44FFFFFF"
                android:max="100"
                android:visibility="gone" />

            <!-- Badge row (top right) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:orientation="vertical"
                android:padding="4dp">

                <TextView
                    android:id="@+id/badge4K"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4K"
                    android:textColor="@color/white"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:background="@drawable/badge_bg_blue"
                    android:paddingHorizontal="5dp"
                    android:paddingVertical="2dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/badgeHdr"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HDR10"
                    android:textColor="@color/white"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:background="@drawable/badge_bg_orange"
                    android:paddingHorizontal="5dp"
                    android:paddingVertical="2dp"
                    android:layout_marginTop="2dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/badge51"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5.1"
                    android:textColor="@color/white"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:background="@drawable/badge_bg_green"
                    android:paddingHorizontal="5dp"
                    android:paddingVertical="2dp"
                    android:layout_marginTop="2dp"
                    android:visibility="gone" />

            </LinearLayout>
        </FrameLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/vodTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:paddingHorizontal="6dp"
            android:paddingTop="6dp" />

        <!-- Codec + Audio badges row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="6dp"
            android:paddingTop="3dp">

            <TextView
                android:id="@+id/badgeCodec"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="9sp"
                android:background="@drawable/badge_bg_dark"
                android:paddingHorizontal="4dp"
                android:paddingVertical="1dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/badgeAudio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="9sp"
                android:background="@drawable/badge_bg_dark"
                android:paddingHorizontal="4dp"
                android:paddingVertical="1dp"
                android:layout_marginStart="4dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Like / Dislike row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:gravity="end"
            android:paddingHorizontal="4dp">

            <ImageButton
                android:id="@+id/btnLike"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_thumb_up_outline"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/accent_green" />

            <ImageButton
                android:id="@+id/btnDislike"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_thumb_down_outline"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/accent_red"
                android:layout_marginStart="4dp" />

        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
