<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Search + Category row -->
    <LinearLayout
        android:id="@+id/vodTopRow"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@color/bg_surface"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.appcompat.widget.SearchView
            android:id="@+id/vodSearchView"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            app:queryHint="Search movies..."
            app:iconifiedByDefault="false" />

        <Button
            android:id="@+id/btnVodCategory"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="Category"
            android:textSize="12sp"
            android:backgroundTint="@color/bg_surface"
            android:textColor="@color/accent_blue" />
    </LinearLayout>

    <!-- Filter chips -->
    <HorizontalScrollView
        android:id="@+id/vodChipsScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/vodTopRow">

        <com.google.android.material.chip.ChipGroup
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipVod4K"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4K Only"
                android:textColor="@color/text_primary"
                app:chipBackgroundColor="@color/chip_selector" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipVodHdr"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HDR"
                android:textColor="@color/text_primary"
                app:chipBackgroundColor="@color/chip_selector" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipVod51"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5.1 Audio"
                android:textColor="@color/text_primary"
                app:chipBackgroundColor="@color/chip_selector" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipVodLiked"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Liked"
                android:textColor="@color/text_primary"
                app:chipBackgroundColor="@color/chip_selector" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipVodUnwatched"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Unwatched"
                android:textColor="@color/text_primary"
                app:chipBackgroundColor="@color/chip_selector" />

        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- Scan Status Bar -->
    <LinearLayout
        android:id="@+id/scanStatusBar"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:background="#1A1A3E"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/vodChipsScroll">

        <ProgressBar
            android:id="@+id/scanProgressSpinner"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:indeterminate="true"
            android:visibility="gone" />

        <TextView
            android:id="@+id/scanStatusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/accent_blue"
            android:textSize="11sp"
            android:paddingStart="8dp"
            android:text="Scanning new content..." />

        <Button
            android:id="@+id/btnScanNow"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:text="Scan Now"
            android:textSize="10sp"
            android:backgroundTint="@color/accent_blue"
            android:textColor="@color/white"
            android:paddingHorizontal="8dp" />

    </LinearLayout>

    <!-- Grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/vodRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/scanStatusBar"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Empty -->
    <TextView
        android:id="@+id/vodEmptyView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No movies found.\nAdd your IPTV server in Settings."
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/vodChipsScroll"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Progress -->
    <ProgressBar
        android:id="@+id/vodProgressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/vodChipsScroll"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
