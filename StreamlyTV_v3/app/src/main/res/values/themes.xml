<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.StreamlyTV" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorPrimaryVariant">@color/bg_surface</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_surface</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
